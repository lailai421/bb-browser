{
  "name": "@wanji/bb-browser-mcp",
  "version": "0.15.1",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "bb-browser-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm --filter @bb-browser/shared build && tsup && node ./scripts/copy-builddomtree.mjs",
    "dev": "tsup --watch",
    "test": "tsx --test src/mcp.test.ts",
    "lint": "eslint src tsup.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@bb-browser/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.0"
  }
}
